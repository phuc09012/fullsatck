{
  "ConnectionStrings": {
    "CirculationDb": "Server=localhost,1433;Database=CirculationDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;Encrypt=False"
  },
  "Jwt": {
    "Issuer": "LibraryAuth",
    "Audience": "LibraryUsers",
    "Key": "ChangeThisKeyToSomethingAtLeast32CharsLong!"
  },
  "InternalApi": {
    "Key": "LibraryInternalSecretChangeMe!"
  },
  "CatalogService": {
    "BaseUrl": "http://localhost:5001"
  },
  "IdentityService": {
    "BaseUrl": "http://localhost:5003"
  },
  "Borrowing": {
    "MaxActiveBorrowingsPerReader": 5,
    "DefaultBorrowDays": 14,
    "MaxRenewalDays": 30,
    "AllowReaderSelfCheckout": true,
    "FinePerOverdueDay": 2000
  },
  "IntegrationEvents": {
    "Subscribers": {
      "book.borrowed": [
        "http://localhost:5003/integration/events/book-borrowed"
      ],
      "book.returned": [
        "http://localhost:5003/integration/events/book-returned"
      ],
      "fine.paid": [
        "http://localhost:5003/integration/events/fine-paid"
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
